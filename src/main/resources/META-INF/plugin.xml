<idea-plugin>
    <id>dev.proofly.getmnemo</id>
    <name>Mnemo</name>
    <vendor email="founders@getmnemo.xyz" url="https://getmnemo.dev">Proofly</vendor>

    <description><![CDATA[
        Persistent memory for AI coding workflows.

        Search, capture, and recall code snippets, decisions, and learnings without leaving the IDE.
        Works in IntelliJ IDEA, WebStorm, PyCharm, GoLand, RubyMine, PhpStorm, CLion, and Rider.
        <br/><br/>
        <b>Features</b>
        <ul>
            <li>Tools menu actions: <i>Search Memory</i> and <i>Add Selection</i></li>
            <li>Right-side tool window with your most recent memories</li>
            <li>Connects to your Mnemo workspace via API key (stored locally)</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <!-- Belt-and-braces fallback for IDE versions that ignore patchPluginXml. -->
    <idea-version since-build="232" until-build="251.*"/>

    <!-- Allow hot-reload (Settings | Plugins | Install/Update without restart). -->
    <change-notes><![CDATA[
        See <a href="https://github.com/getmnemo/getmnemo-jetbrains/releases">GitHub releases</a>.
    ]]></change-notes>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Mnemo"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowFavorites"
            factoryClass="dev.proofly.getmnemo.ui.MnemoToolWindowFactory"/>
        <postStartupActivity implementation="dev.proofly.getmnemo.MnemoStartup"/>
        <applicationService serviceImplementation="dev.proofly.getmnemo.services.MnemoService"/>
    </extensions>

    <actions>
        <group id="Mnemo.MainGroup" text="Mnemo" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="Mnemo.Search"
                    class="dev.proofly.getmnemo.actions.SearchMemoryAction"
                    text="Search Memory"
                    description="Search Mnemo">
                <keyboard-shortcut keymap="$default" first-keystroke="control alt M"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt M"/>
            </action>
            <action id="Mnemo.AddSelection"
                    class="dev.proofly.getmnemo.actions.AddSelectionAction"
                    text="Add Selection"
                    description="Save the selected text to Mnemo">
                <keyboard-shortcut keymap="$default" first-keystroke="control alt A"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt A"/>
            </action>
        </group>
    </actions>
</idea-plugin>
